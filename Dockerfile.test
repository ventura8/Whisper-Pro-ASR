# Stage 1: Base - Install dependencies and cache them
FROM python:3.14-slim AS base

USER root
ENV PYTHONUNBUFFERED=1

# Install system dependencies
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y ffmpeg git build-essential && rm -rf /var/lib/apt/lists/*

# Install Python libraries and upgrade dependencies
COPY pip.conf /etc/pip.conf
COPY test_requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install --upgrade pip && \
    python3 -m pip install -r test_requirements.txt

WORKDIR /app

# Stage 2: Lint - Run static analysis (Cached by Docker)
FROM base AS lint
COPY . .
RUN yamllint -c .yamllint . && \
    python3 -m autopep8 --diff --exit-code --recursive --max-line-length 140 modules tests whisper_pro_asr.py scripts && \
    python3 -m pylint --rcfile=.pylintrc modules tests whisper_pro_asr.py --recursive=y

# Stage 3: Test - Final image for running integration tests
FROM base AS test
COPY . .
RUN sed -i 's/\r$//' tests/run_suite.sh && chmod +x tests/run_suite.sh

# Default command
CMD ["/bin/bash", "tests/run_suite.sh"]
